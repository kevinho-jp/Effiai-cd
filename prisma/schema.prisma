generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Produit {
  id          String   @id @default(cuid())
  nom         String
  description String   @db.Text
  prix        Float
  fichierUrl  String
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  commandes   Commande[]
}

model Admin {
  id       String @id @default(cuid())
  email    String @unique
  password String?
}

model Commande {
  id                 String   @id @default(cuid())
  produitId          String
  produit            Produit  @relation(fields: [produitId], references: [id], onDelete: Cascade)
  emailClient        String
  prixTotal          Float
  statutPaiement     String   @default("en_attente")
  paypalOrderId      String?  @unique
  lienTelechargement String?
  creeLe             DateTime @default(now())
}
